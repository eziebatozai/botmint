# ============================================
# LOBSTER NFT - FCFS MINT BOT
# https://lobsternft.lol/mint
# Contract: 0x1de237c7063a9ee531e06a6c3fba4e3e704f2a74
# Type: Thirdweb ERC721Drop (claim function)
# Chain: Ethereum Mainnet
# ============================================

# === RPC (gunakan premium RPC untuk speed terbaik!) ===
# Recommended: Alchemy, Infura, QuickNode
RPC_URL=https://eth.llamarpc.com
RPC_URLS_BACKUP=https://rpc.ankr.com/eth,https://ethereum.publicnode.com,https://1rpc.io/eth
CHAIN_ID=1

# === CONTRACT (Lobster NFT - Thirdweb ERC721Drop) ===
CONTRACT_ADDRESS=0x1de237c7063a9ee531e06a6c3fba4e3e704f2a74
# Mint price dalam ETH (0 = free mint, atau diisi otomatis dari claim condition)
MINT_PRICE=0
# Jumlah NFT per claim
MINT_AMOUNT=1
MAX_PER_WALLET=1

# === THIRDWEB CLAIM SETTINGS ===
# Currency untuk pembayaran (default: native ETH)
# 0xEeee...EEeE = native ETH, atau alamat ERC20 token
CURRENCY=0xEeeeeEeeeEeEeeEeEeEeeEEEeeeeEeeeeeeeEEeE

# Allowlist proof (kosongkan untuk public mint)
# QUANTITY_LIMIT_PER_WALLET=0
# ALLOWLIST_PRICE=0
# ALLOWLIST_CURRENCY=0xEeeeeEeeeEeEeeEeEeEeeEEEeeeeEeeeeeeeEEeE

# === COLLECTION INFO ===
COLLECTION_NAME=Lobster NFT
COLLECTION_URL=https://lobsternft.lol/mint

# === WALLET ===
# Single wallet
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
# Multi wallet (comma separated) - untuk FCFS lebih banyak chance!
# PRIVATE_KEYS=0xKEY1,0xKEY2,0xKEY3

# === GAS (AGRESIF untuk FCFS!) ===
# Naikkan untuk prioritas lebih tinggi di mempool
MAX_GAS_PRICE_GWEI=100
PRIORITY_FEE_GWEI=5
GAS_LIMIT=300000
GAS_MULTIPLIER=1.5

# === SPEED MODE ===
# "turbo" = max gas, aggressive nonce (RECOMMENDED untuk FCFS)
# "normal" = standard execution
SPEED_MODE=turbo

# === BOT MODE ===
# "monitor" = auto-detect saat claim buka via claimCondition, lalu claim (RECOMMENDED)
# "instant" = langsung claim sekarang
# "countdown" = claim pada waktu tertentu (set MINT_START_TIME)
BOT_MODE=monitor

# === COUNTDOWN MODE (optional) ===
# Unix timestamp atau ISO date: "2025-01-15T14:00:00Z"
MINT_START_TIME=
# Kirim TX lebih awal (ms sebelum start time)
COUNTDOWN_OFFSET_MS=2000

# === POLLING & RETRY ===
POLL_INTERVAL_MS=1000
MAX_RETRIES=5
RETRY_DELAY_MS=500

# === NOTIFICATIONS ===
ENABLE_NOTIFICATIONS=true

# === ADVANCED: FLASHBOTS (MEV Protection) ===
# USE_FLASHBOTS=true
# FLASHBOTS_RPC=https://rpc.flashbots.net
