# ============================================
# LOBSTER NFT - FCFS MINT BOT
# https://lobsternft.lol/mint
# ============================================

# === RPC (gunakan premium RPC untuk speed terbaik!) ===
# Recommended: Alchemy, Infura, QuickNode
RPC_URL=https://eth.llamarpc.com
RPC_URLS_BACKUP=https://rpc.ankr.com/eth,https://ethereum.publicnode.com,https://1rpc.io/eth
CHAIN_ID=1

# === CONTRACT (Lobster NFT) ===
# ISI CONTRACT ADDRESS dari lobsternft.lol/mint!
# Cek di Etherscan atau inspect element di website mint
CONTRACT_ADDRESS=
MINT_PRICE=0
MINT_AMOUNT=1
MAX_PER_WALLET=1

# === MINT FUNCTION ===
# Options: mint, publicMint, mintPublic, claim, purchase, safeMint, mintNFT, buy, custom
# Cek function name di Etherscan -> Contract -> Write Contract
MINT_FUNCTION=mint
# Jika MINT_FUNCTION=custom, isi signature:
# CUSTOM_MINT_SIG=mint(uint256)

# === COLLECTION INFO ===
COLLECTION_NAME=Lobster NFT
COLLECTION_URL=https://lobsternft.lol/mint

# === WALLET ===
# Single wallet
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
# Multi wallet (comma separated) - untuk FCFS lebih banyak chance!
# PRIVATE_KEYS=0xKEY1,0xKEY2,0xKEY3

# === GAS (AGRESIF untuk FCFS!) ===
# Naikkan untuk prioritas lebih tinggi di mempool
MAX_GAS_PRICE_GWEI=100
PRIORITY_FEE_GWEI=5
GAS_LIMIT=300000
GAS_MULTIPLIER=1.5

# === SPEED MODE ===
# "turbo" = max gas, aggressive nonce, pre-sign TX (RECOMMENDED untuk FCFS)
# "normal" = standard execution
SPEED_MODE=turbo

# Pre-sign transactions sebelum mint aktif (true/false)
PRE_SIGN=true

# Jumlah TX paralel per wallet (lebih tinggi = lebih banyak chance, tapi lebih mahal)
PARALLEL_TX=1

# === BOT MODE ===
# "monitor" = auto-detect saat mint buka, lalu mint (RECOMMENDED)
# "instant" = langsung mint sekarang
# "countdown" = mint pada waktu tertentu (set MINT_START_TIME)
BOT_MODE=monitor

# === COUNTDOWN MODE (optional) ===
# Unix timestamp atau ISO date: "2025-01-15T14:00:00Z"
MINT_START_TIME=
# Kirim TX lebih awal (ms sebelum start time)
COUNTDOWN_OFFSET_MS=2000

# === POLLING & RETRY ===
POLL_INTERVAL_MS=1000
MAX_RETRIES=5
RETRY_DELAY_MS=500

# === NOTIFICATIONS ===
ENABLE_NOTIFICATIONS=true

# === ADVANCED: FLASHBOTS (MEV Protection) ===
# USE_FLASHBOTS=true
# FLASHBOTS_RPC=https://rpc.flashbots.net
