# ============================================
# BOTMINT FCFS - SIGNED PRESALE CONFIGURATION
# ============================================

# === RPC ===
RPC_URL=https://mainnet.base.org
RPC_URLS_BACKUP=https://base.meowrpc.com,https://base.drpc.org
CHAIN_ID=8453

# === CONTRACT ===
CONTRACT_ADDRESS=0xYOUR_NFT_CONTRACT_ADDRESS
MINT_PRICE=0
MINT_AMOUNT=1
MAX_PER_WALLET=1

# === FCFS / SIGNED PRESALE ===
# Slug koleksi di OpenSea (dari URL: opensea.io/collection/YOUR-SLUG)
COLLECTION_SLUG=your-collection-slug
# Stage index untuk FCFS (lihat dari data drop OpenSea, biasanya 1 atau 2)
STAGE_INDEX=2
# OpenSea API key (opsional, tapi direkomendasikan untuk avoid rate limit)
OPENSEA_API_KEY=

# === WALLET ===
# Single wallet
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# Multi wallet (comma separated)
# PRIVATE_KEYS=0xKEY1,0xKEY2,0xKEY3

# === GAS (Base L2 = super murah) ===
MAX_GAS_PRICE_GWEI=1
PRIORITY_FEE_GWEI=0.1
GAS_MULTIPLIER=1.2

# === BOT MODE ===
# "monitor" = polling sampai stage aktif, lalu auto-mint
# "instant" = langsung mint (pastikan stage sudah aktif!)
BOT_MODE=monitor
POLL_INTERVAL_MS=1000
MAX_RETRIES=3
RETRY_DELAY_MS=500

# === NOTIFICATIONS ===
ENABLE_NOTIFICATIONS=true
