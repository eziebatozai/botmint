# ============================================
# BOTMINT - LACERTIANS PUBLIC MINT (OpenSea Drop)
# ============================================

# === RPC (Ethereum Mainnet) ===
RPC_URL=https://eth.llamarpc.com
RPC_URLS_BACKUP=https://rpc.ankr.com/eth,https://ethereum.publicnode.com
CHAIN_ID=1

# === CONTRACT (Lacertians) ===
CONTRACT_ADDRESS=0x35f39c6bc77ae5fec20c29b5212a77509fdbaf03
MINT_PRICE=0.006
MINT_AMOUNT=1
MAX_PER_WALLET=5

# === OPENSEA DROP / SIGNED PRESALE ===
# Slug koleksi di OpenSea (dari URL: opensea.io/collection/lacertians)
COLLECTION_SLUG=lacertians
# Stage index (0=Public, 1=WL PASS, 2=FCFS - cek dari OpenSea drop info)
STAGE_INDEX=1
# OpenSea API key (opsional, tapi direkomendasikan untuk avoid rate limit)
OPENSEA_API_KEY=

# === WALLET ===
# Single wallet
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# Multi wallet (comma separated)
# PRIVATE_KEYS=0xKEY1,0xKEY2,0xKEY3

# === GAS (Ethereum Mainnet) ===
MAX_GAS_PRICE_GWEI=50
PRIORITY_FEE_GWEI=2
GAS_MULTIPLIER=1.3

# === BOT MODE ===
# "monitor" = polling sampai stage aktif, lalu auto-mint
# "instant" = langsung mint (pastikan stage sudah aktif!)
BOT_MODE=monitor
POLL_INTERVAL_MS=2000
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# === NOTIFICATIONS ===
ENABLE_NOTIFICATIONS=true
