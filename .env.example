# ============================================
# BOT MINT FCFS - KONFIGURASI
# ============================================

# RPC Provider (gunakan Alchemy/Infura/QuickNode untuk kecepatan terbaik)
# Ethereum Mainnet
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# Atau gunakan beberapa RPC untuk failover (pisahkan dengan koma)
RPC_URLS_BACKUP=https://mainnet.infura.io/v3/YOUR_KEY,https://rpc.ankr.com/eth

# Private Key wallet (JANGAN SHARE KE SIAPAPUN!)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Jika ingin multi-wallet, tambahkan private key dipisah koma
# PRIVATE_KEYS=0xKEY1,0xKEY2,0xKEY3

# ============================================
# CONTRACT SETTINGS
# ============================================

# Contract address NFT (The Bamboo Order)
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# Mint function signature (contoh umum)
# Sesuaikan dengan ABI contract yang benar
MINT_FUNCTION=mint
# Atau bisa juga: publicMint, mintPublic, claim, dll

# Harga mint per NFT (dalam ETH)
MINT_PRICE=0.0

# Jumlah NFT yang ingin di-mint per transaksi
MINT_AMOUNT=1

# Max mint per wallet (sesuaikan dengan rules project)
MAX_PER_WALLET=1

# ============================================
# GAS SETTINGS
# ============================================

# Max gas price (dalam Gwei) - proteksi dari gas war
MAX_GAS_PRICE_GWEI=100

# Priority fee / tip (dalam Gwei)
PRIORITY_FEE_GWEI=2

# Gas limit (biarkan 0 untuk auto-estimate)
GAS_LIMIT=0

# Multiplier gas estimate (1.2 = 20% buffer)
GAS_MULTIPLIER=1.2

# ============================================
# BOT SETTINGS
# ============================================

# Mode: "monitor" (tunggu mint buka) atau "instant" (langsung mint)
BOT_MODE=monitor

# Interval polling dalam milidetik (untuk mode monitor)
POLL_INTERVAL_MS=1000

# Jumlah retry jika gagal
MAX_RETRIES=3

# Delay antar retry (ms)
RETRY_DELAY_MS=500

# Aktifkan notifikasi desktop (true/false)
ENABLE_NOTIFICATIONS=true

# Chain ID (1 = Ethereum Mainnet, 11155111 = Sepolia Testnet)
CHAIN_ID=1
